# Copie este arquivo para `.streamlit/secrets.toml` (gitignored) ou cole o
# conteúdo em share.streamlit.io → App → Settings → Secrets.
# NUNCA inclua a SUPABASE_SERVICE_ROLE_KEY aqui — RLS depende do anon key.

SUPABASE_URL = "https://<seu-projeto>.supabase.co"
SUPABASE_ANON_KEY = "<anon public key do projeto Supabase>"

# URL para onde o Google OAuth deve redirecionar após o login. Em dev use
# http://localhost:8501. Em produção, a URL do app no Streamlit Cloud
# (ex.: https://bi-topstep.streamlit.app). Precisa estar listada em
# Supabase → Authentication → URL Configuration → Redirect URLs.
APP_URL = "http://localhost:8501"
